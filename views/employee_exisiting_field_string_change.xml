<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_employee_form_inherit_tab_change" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.tab</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- tab string change -->
            <xpath expr="//page[@name='personal_information']" position="attributes">
                <attribute name="string">Staff Profile</attribute>
            </xpath>

            <!-- field string change -->
            <xpath expr="//field[@name='work_email']" position="attributes">
                <attribute name="string">Official Email</attribute>
            </xpath>

            <xpath expr="//field[@name='passport_id']" position="attributes">
                <attribute name="string">NID / Passport Number</attribute>
            </xpath>

            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="string">Nationality</attribute>
            </xpath>

            <xpath expr="//field[@name='emergency_contact']" position="attributes">
                <attribute name="string">Emergency Contact Name</attribute>
            </xpath>

            <xpath expr="//field[@name='emergency_phone']" position="attributes">
                <attribute name="string">Emergency Contact Phone</attribute>
            </xpath>


            <xpath expr="//field[@name='private_email']" position="attributes">
                <attribute name="string">Personal Email (optional)</attribute>
            </xpath>

            <xpath expr="//field[@name='private_phone']" position="attributes">
                <attribute name="string">Mobile Number (Primary)</attribute>
            </xpath>

            <!-- Change Group Title -->
            <xpath expr="//page[@name='personal_information']/group/group[1]" position="attributes">
                <attribute name="string">Basic Info</attribute>
            </xpath>

            <!-- Change Label -->
            <xpath expr="//label[@for='private_street']" position="attributes">
                <attribute name="string">Permanent Address</attribute>
            </xpath>


        </field>
    </record>

</odoo>