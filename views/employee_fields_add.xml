<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_employee_filter_inherit_staff_id" model="ir.ui.view">
        <field name="name">hr.employee.search.inherit.staff.id</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='name']" position="attributes">
                <attribute name="filter_domain">['|', '|', ('work_email', 'ilike', self), ('name', 'ilike', self), ('staff_id', 'ilike', self)]</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_employee_form_inherit_tab_field-add" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.tab.add.field</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="profile_completion" readonly="1" widget="progressbar"/>
                <field name="employment_status" widget="statusbar" options="{'clickable': True}"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='private_email']" position="before">
                <field name="staff_id"/>
                <field name="full_name"/>
                <field name="mother_name"/>
                <field name="father_name"/>
                <field name="date_of_joining"/>
                <field name="employment_status" readonly="1"/>
                <field name="employment_type"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//div[@class='o_address_format'][field[@name='private_street']]"
                   position="after">
                <label for="present_street" string="Present Address"/>
                <div class="o_address_format">
                    <field name="present_street" placeholder="Street..." class="o_address_street"/>
                    <field name="present_street2" placeholder="Street 2..." class="o_address_street"/>
                    <field name="present_city" placeholder="City" class="o_address_city"/>
                    <field name="present_state_id" class="o_address_state" placeholder="State"
                           options="{'no_open': True, 'no_quick_create': True}"
                           context="{'default_country_id': present_country_id}"/>
                    <field name="present_zip" placeholder="ZIP" class="o_address_zip"/>
                    <field name="present_country_id" placeholder="Country" class="o_address_country"
                           options='{"no_open": True, "no_create": True}'/>
                </div>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='private_phone']" position="after">
                <field name="mobile_alt"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='emergency_contact']" position="after">
                <field name="emergency_contact_relationship"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//group[@name='emergency']" position="after">
                <group string="Emergency Contact (Name, Relationship, Phone)" name="emergency_contact_line_group">
                    <field name="emergency_contact_line_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="relationship"/>
                            <field name="phone"/>
                        </tree>
                    </field>
                </group>
            </xpath>

            <xpath expr="//page[@name='personal_information']/group" position="inside">
                <group string="Salary &amp; Benefits">
                    <field name="payment_mode"/>
                    <field name="bank_name"/>
                    <field name="account_number" />
                    <field name="mobile_banking_number" />
                    <field name="monthly_gross_salary" readonly="1"/>
                </group>
            </xpath>

            <xpath expr="//page[@name='personal_information']/group" position="inside">
                <group name="documents_qualification_wrapper" colspan="2">
                    <separator string="Documents Upload" colspan="2"/>
                    <group>
                        <field name="resume_file" filename="resume_filename"/>
                        <field name="appointment_letter_file" filename="appointment_letter_filename"/>
                        <field name="contract_agreement_file" filename="contract_agreement_filename"/>
                        <field name="id_card" filename="id_card_filename"/>
                    </group>
                    <group>
                        <field name="passport_copy_file" filename="passport_copy_filename"/>
                        <field name="academic_certificates_file" filename="academic_certificates_filename"/>
                        <field name="photograph_file" filename="photograph_filename"/>
                        <field name="driving_license" filename="driving_license_filename"/>
                        <field name="others_certificate_file" filename="others_certificate_filename"/>
                    </group>
                </group>

                <group string="Academic &amp; Professional Qualifications" colspan="2">
                    <field name="qualification_line_ids" mode="tree,form" nolabel="1" colspan="2">
                        <tree editable="bottom">
                            <field name="highest_education_level"/>
                            <field name="degree_certificate_name"/>
                            <field name="institution_name"/>
                            <field name="passing_year"/>
                            <field name="major_subject"/>
                            <field name="professional_training"/>
                            <field name="training_details"/>
                        </tree>
                        <form>
                            <group>
                                <field name="highest_education_level"/>
                                <field name="degree_certificate_name"/>
                                <field name="institution_name"/>
                                <field name="passing_year"/>
                                <field name="major_subject"/>
                                <field name="professional_training"/>
                                <field name="training_details"/>
                            </group>
                        </form>
                    </field>
                </group>

                <group string="Experience Record" colspan="2">
                    <field name="total_years_experience"/>
                    <field name="previous_organization_name"/>
                    <field name="previous_designation"/>
                    <field name="work_location"/>
                    <field name="previous_position">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="company"/>
                            <field name="from_date"/>
                            <field name="to_date"/>
                        </tree>
                    </field>
                    <field name="duration_from"/>
                    <field name="duration_to"/>
                    <field name="key_responsibilities"/>
                </group>

            </xpath>


            <xpath expr="//page[@name='personal_information']//field[@name='spouse_complete_name']" position="after">
                <field name="spouse_occupation"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='children']" position="after">
                <field name="total_dependents"/>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='total_dependents']" position="after">
                <field name="child_line_ids">
                    <tree editable="bottom">
                        <field name="name" string="Child Name"/>
                        <field name="gender"/>
                    </tree>
                </field>
            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='child_line_ids']" position="after">
                <field name="child_education_line_ids">
                    <tree editable="bottom">
                        <field name="name" string="Child Name"/>
                        <field name="class_name"/>
                        <field name="school_name"/>
                    </tree>
                </field>
            </xpath>

        </field>
    </record>

</odoo>
